*.log

# Environment files (important)
.env

# Temporary files
*.tmp
*.temp

# Cache folders
.cache/
dist/
build/

# Python (just in case future AI work)
__pycache__/
*.pyc

# Java (since tu Java bhi karta hai)
*.class
*.jar
*.war
*.ear
out/

# Large images or raw files (optional)
# Agar tu chahe to ignore kar sakta hai:
# *.png
# *.jpg
# *.jpeg

